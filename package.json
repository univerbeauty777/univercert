{
  "name": "univercert",
  "version": "0.2.0",
  "private": true,
  "description": "UniverCert · plataforma brasileira de certificados digitais",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "pages:build": "npx @cloudflare/next-on-pages",
    "db:generate": "drizzle-kit generate",
    "db:push:local": "wrangler d1 execute univercert-mvp --local --file=./drizzle/migrations/0000_init.sql",
    "db:push:remote": "wrangler d1 execute univercert-mvp --remote --file=./drizzle/migrations/0000_init.sql",
    "db:studio": "drizzle-kit studio",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "better-auth": "1.6.9",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "next": "15.0.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0",
    "vercel": "^41.7.4",
    "wrangler": "^3.85.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
