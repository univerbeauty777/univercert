# UniverCert · variáveis de ambiente para desenvolvimento local
# Copie como .env.local — NÃO commitar!

# ----------------------------------------
# Cloudflare (provisionado via Cowork)
# ----------------------------------------
CLOUDFLARE_ACCOUNT_ID=4a89b58af57b3ffb99858479a75b1e61
CLOUDFLARE_D1_DATABASE_ID=161fc60a-d5d3-4722-8c04-d8120f2682bc
CLOUDFLARE_R2_BUCKET=univercert-assets
CLOUDFLARE_KV_NAMESPACE_ID=155def9a0c5249bca41686d25e4f7208

# ----------------------------------------
# App
# ----------------------------------------
APP_NAME=UniverCert
APP_URL=http://localhost:3000          # local dev · em prod = https://univercert.com.br
NODE_ENV=development

# ----------------------------------------
# Better Auth
# ----------------------------------------
BETTER_AUTH_SECRET=                    # gerar: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=                # criar em console.cloud.google.com
GOOGLE_OAUTH_CLIENT_SECRET=

# ----------------------------------------
# Email · Resend
# ----------------------------------------
RESEND_API_KEY=                        # https://resend.com/api-keys
RESEND_FROM_EMAIL=no-reply@univercert.com.br
RESEND_FROM_NAME=UniverCert

# ----------------------------------------
# WhatsApp · Meta Cloud API
# ----------------------------------------
META_WHATSAPP_TOKEN=                   # Meta Business Manager > Sistema
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_VERIFY_TOKEN=            # qualquer string que você define

# ----------------------------------------
# Pagamento · Asaas (Pix + Boleto + Cartão)
# ----------------------------------------
ASAAS_API_KEY=                         # asaas.com > Integrações > API
ASAAS_ENV=sandbox                      # sandbox | production

# ----------------------------------------
# Nota Fiscal · NFE.io
# ----------------------------------------
NFEIO_API_KEY=                         # nfe.io > API Keys
NFEIO_COMPANY_ID=

# ----------------------------------------
# Webhooks de entrada · secrets dos provedores
# ----------------------------------------
HOTMART_WEBHOOK_SECRET=
MEMBERKIT_WEBHOOK_SECRET=
KIWIFY_WEBHOOK_SECRET=
EDUZZ_WEBHOOK_SECRET=
FLUENT_WEBHOOK_SECRET=

# ----------------------------------------
# Observabilidade
# ----------------------------------------
SENTRY_DSN=
POSTHOG_KEY=

# ----------------------------------------
# Claude API (para AI features Sprint 7)
# ----------------------------------------
ANTHROPIC_API_KEY=
